    "lint": "npm run lint --workspace web && npm run lint --workspace api"
  },
  "dependencies": {
    "@mediapipe/face_mesh": "^0.4.1633559619",
    "@mediapipe/pose": "^0.5.1675469404",
    "@tensorflow-models/face-landmarks-detection": "^1.0.6",
    "@tensorflow/tfjs": "^4.22.0",
    "react-webcam": "^7.2.0",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "lightningcss": "^1.32.0"
  }
}
